# 管理员密码（必填）
ADMIN_PASSWORD=your_secure_password_here

# Session 加密密钥（至少 32 个字符）
SESSION_SECRET=complex_password_at_least_32_characters_long

# 默认语言（可选，默认 zh-hk）
DEFAULT_LANG=zh-hk

# 网站基础 URL（用于 SEO、sitemap）
NEXT_PUBLIC_BASE_URL=https://bncleague.com

# YouTube Data API v3 密钥（可选，未配置时使用 RSS 获取视频）
YOUTUBE_API_KEY=

# YouTube 频道 ID（RSS 备用，默认 @BNCChampion）
YOUTUBE_CHANNEL_ID=UCeAfUfcP8r1wrRvgnQmljZA

# Facebook Graph API（可选，未配置时使用 Page Plugin 嵌入）
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=100094558236356

# ScoreLab 基础 URL（可选，默认 https://www.scorelab.tech）
NEXT_PUBLIC_SCORELAB_BASE_URL=https://www.scorelab.tech
